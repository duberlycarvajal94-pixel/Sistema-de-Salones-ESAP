  TIPO=t;
  document.querySelectorAll('.tipo-tab').forEach(b=>b.classList.toggle('on',b.dataset.tipo===t));
  ['dep','est','ext'].forEach(x=>document.getElementById('sec-'+x).classList.toggle('on',x===t));
}
function onDepChange(){document.getElementById('campoDepOtro').style.display=document.getElementById('fDepSel').value==='otro'?'block':'none';}

function abrirNuevaReserva(){
  EDID=null; selTipo('dep');
  document.getElementById('rsvTit').innerHTML='<i class="bi bi-calendar-plus"></i> Nueva Reserva';
  document.getElementById('btnDel').style.display='none';
