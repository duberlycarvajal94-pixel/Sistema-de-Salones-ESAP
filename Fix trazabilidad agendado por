    else{ds.value='otro';document.getElementById('fDepOtro').value=r.dependencia||'';document.getElementById('campoDepOtro').style.display='block';}
    document.getElementById('fDepResp').value=r.responsable||'';
    document.getElementById('fDepCorreo').value=r.correo||'';
    document.getElementById('fDepTel').value=r.telefono||'';
  }else if(t==='est'){
    document.getElementById('fEstNombre').value=r.estNombre||'';
    document.getElementById('fEstDoc').value=r.estDoc||'';
    document.getElementById('fEstProg').value=r.estProg||'';
    document.getElementById('fEstCorreo').value=r.estCorreo||'';
    document.getElementById('fEstTel').value=r.estTel||'';
  }else{
    document.getElementById('fExtEntidad').value=r.extEnt||'';
    document.getElementById('fExtResp').value=r.extRes||'';
    document.getElementById('fExtDoc').value=r.extDoc||'';
    document.getElementById('fExtCorreo').value=r.extCorreo||'';
    document.getElementById('fExtTel').value=r.extTel||'';
  }
  cerrar('ovDet');
  document.getElementById('ovRsv').classList.add('open');
}

function limpiarCampos(){
  ['fDepSel','fEvento','fObs','fDepResp','fDepCorreo','fDepTel','fDepOtro','fEstNombre','fEstDoc','fEstProg','fEstCorreo','fEstTel','fExtEntidad','fExtResp','fExtDoc','fExtCorreo','fExtTel'].forEach(id=>{const e=document.getElementById(id);if(e)e.value='';});
  document.getElementById('fSalon').value='';
  document.getElementById('campoDepOtro').style.display='none';
}

function leerFormulario(){
  const obj={tipo:TIPO,aula:document.getElementById('fSalon').value,evento:document.getElementById('fEvento').value.trim(),fecha:document.getElementById('fFecha').value,hi:document.getElementById('fHI').value,hf:document.getElementById('fHF').value,estado:document.getElementById('fEstado').value,obs:document.getElementById('fObs').value.trim(),ts:Date.now()};
  if(TIPO==='dep'){
    const dv=document.getElementById('fDepSel').value;
    const dep=dv==='otro'?document.getElementById('fDepOtro').value.trim():dv;
    Object.assign(obj,{dependencia:dep,responsable:document.getElementById('fDepResp').value.trim(),correo:document.getElementById('fDepCorreo').value.trim(),telefono:document.getElementById('fDepTel').value.trim()});
  }else if(TIPO==='est'){
    Object.assign(obj,{estNombre:document.getElementById('fEstNombre').value.trim(),estDoc:document.getElementById('fEstDoc').value.trim(),estProg:document.getElementById('fEstProg').value.trim(),estCorreo:document.getElementById('fEstCorreo').value.trim(),estTel:document.getElementById('fEstTel').value.trim(),dependencia:'Estudiante',responsable:document.getElementById('fEstNombre').value.trim(),correo:document.getElementById('fEstCorreo').value.trim()});
  }else{
    Object.assign(obj,{extEnt:document.getElementById('fExtEntidad').value.trim(),extRes:document.getElementById('fExtResp').value.trim(),extDoc:document.getElementById('fExtDoc').value.trim(),extCorreo:document.getElementById('fExtCorreo').value.trim(),extTel:document.getElementById('fExtTel').value.trim(),dependencia:document.getElementById('fExtEntidad').value.trim(),responsable:document.getElementById('fExtResp').value.trim(),correo:document.getElementById('fExtCorreo').value.trim()});
  }
  return obj;
}

function validarForm(obj){
  if(!obj.aula||!obj.evento||!obj.fecha||!obj.hi||!obj.hf)return'Complete espacio, evento, fecha y horario.';
  if(obj.hf<=obj.hi)return'La hora fin debe ser posterior a la de inicio.';
  if(TIPO==='dep'&&(!obj.dependencia||!obj.responsable||!obj.correo))return'Complete dependencia, responsable y correo.';
  if(TIPO==='est'&&(!obj.estNombre||!obj.estCorreo))return'Complete nombre y correo del estudiante.';
  if(TIPO==='ext'&&(!obj.extEnt||!obj.extRes||!obj.extCorreo))return'Complete entidad, responsable y correo del externo.';
  const em=correo(obj);if(em&&!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(em))return'El correo electrónico no es válido.';
  return null;
}

async function guardarRsv(){
  if(!USUARIO_ACTUAL||!['admin','gestor'].includes(USUARIO_ACTUAL.rol)){toast('⛔ No tiene permisos para guardar reservas.','err');return;}
  const obj=leerFormulario();
  const err=validarForm(obj);if(err)return showAlerta('⚠️ '+err);
  const fD=strD(obj.fecha);
  const cc=CLS.find(c=>c.aula===obj.aula&&fD>=strD(c.fi)&&fD<=strD(c.ff)&&esL(obj.fecha)&&solapa(obj.hi,obj.hf,c.hi,c.hf));
  if(cc)return showAlerta('⚠️ Conflicto con clase "'+cc.asignatura+'" ('+cc.hi+'–'+cc.hf+').');
  const rc=rsvArr().find(r=>{const k=Object.keys(RSV).find(k=>RSV[k]===r);return k!==EDID&&r.aula===obj.aula&&r.fecha===obj.fecha&&solapa(obj.hi,obj.hf,r.hi,r.hf);});
  if(rc)return showAlerta('⚠️ Conflicto con reserva "'+rc.evento+'" ('+rc.hi+'–'+rc.hf+').');
  document.getElementById('rsvAlerta').className='alerta-form';
  const btn=document.getElementById('btnGuardar');btn.innerHTML='<span class="spinner"></span>';btn.disabled=true;
  try{
    if(!modoLocal){if(EDID){await dbRef.child(EDID).set({...obj,id:EDID});}else{const nr=dbRef.push();obj.id=nr.key;await nr.set(obj);}}
    else{if(EDID){RSV[EDID]={...obj,id:EDID};}else{const id='loc_'+Date.now();obj.id=id;RSV[id]=obj;}saveLocal();render();}
    // Registrar auditoría ANTES de guardar
  if(!EDID){
    obj.creadoPor = USUARIO_ACTUAL ? USUARIO_ACTUAL.nombre : 'Sistema';
    obj.fechaCreacion = fmtD(new Date());
  } else {
    obj.editadoPor = USUARIO_ACTUAL ? USUARIO_ACTUAL.nombre : 'Sistema';
    obj.fechaEdicion = fmtD(new Date());
  }
  if(!EDID&&obj.estado==='confirmada')await enviarCorreo(obj);
    const ok=document.getElementById('rsvOk');ok.textContent='✅ Reserva '+(EDID?'actualizada':'guardada')+'. Se envió confirmación al correo.';ok.className='alerta-ok on';
    setTimeout(()=>cerrar('ovRsv'),1800);
    toast(EDID?'✓ Actualizada':'✓ Guardada y confirmación enviada','ok');
  }catch(e){toast('❌ Error al guardar','err');}
  finally{btn.innerHTML='<i class="bi bi-check-lg"></i> Guardar Reserva';btn.disabled=false;}
}

async function enviarCorreo(r){
  const em=correo(r);
  if(!em){toast('⚠️ Sin correo del solicitante — no se envió confirmación','warn');return;}
  if(!CFG.EJS_PUB||!CFG.EJS_SVC||!CFG.EJS_TPL){toast('ℹ️ EmailJS pendiente de configurar','info');return;}
  try{
    emailjs.init({publicKey: CFG.EJS_PUB});
    const s=CAT.find(x=>x.id===r.aula)||{n:r.aula,cap:'—',e:{}};
    const eq=Object.entries(s.e||{}).filter(([k,v])=>v&&EN[k]).map(([k])=>EN[k]).join(', ')||'Equipamiento básico';
    const params = {
      to_email:       em,
      email:          em,
      to_name:        nombre(r)||'Solicitante',
      from_name:      'Gestión de Aulas ESAP',
      reply_to:       CFG.CORREO,
      salon:          s.n||r.aula,
      capacidad:      String(s.cap||'—'),
      equipamiento:   eq,
      evento:         r.evento||'—',
      fecha:          mesL(r.fecha),
      hora_inicio:    r.hi||'—',
      hora_fin:       r.hf||'—',
      responsable:    r.responsable||nombre(r)||'—',
      dependencia:    depLabel(r)||'—',
      observaciones:  r.obs||'Sin observaciones adicionales.',
    };
    await emailjs.send(CFG.EJS_SVC, CFG.EJS_TPL, params);
    toast('📧 Confirmación enviada a '+em,'ok');
  }catch(e){
    console.error('EmailJS error:',e);
    toast('⚠️ Reserva guardada. Error al enviar correo: '+( e.text||e.message||'verificar configuración EmailJS'),'warn');
  }
}

async function eliminarRsv(){
  if(!USUARIO_ACTUAL||!['admin'].includes(USUARIO_ACTUAL.rol)){toast('⛔ Solo el administrador puede eliminar reservas.','err');return;}
  if(!EDID||!confirm('¿Eliminar esta reserva? Esta acción no se puede deshacer.'))return;
  try{if(!modoLocal){await dbRef.child(EDID).remove();}else{delete RSV[EDID];saveLocal();render();}cerrar('ovRsv');toast('Reserva eliminada.','warn');}
  catch(e){toast('❌ Error al eliminar','err');}
}
async function delById(id){if(!confirm('¿Eliminar esta reserva?'))return;EDID=id;await eliminarRsv();EDID=null;}

async function cambiarEstado(id, nuevoEstado){
  if(!USUARIO_ACTUAL||!['admin','gestor'].includes(USUARIO_ACTUAL.rol)){
    toast('⛔ Sin permisos para cambiar estado','err');return;
  }
  const r=RSV[id];if(!r)return;
  const actualizado={...r,estado:nuevoEstado,aprobadoPor:USUARIO_ACTUAL.nombre,fechaAprobacion:fmtD(new Date())};
  try{
    if(!modoLocal){await dbRef.child(id).set(actualizado);}
    else{RSV[id]=actualizado;saveLocal();render();}
    cerrar('ovDet');
    toast(nuevoEstado==='confirmada'?'✅ Reserva aprobada':'❌ Reserva rechazada', nuevoEstado==='confirmada'?'ok':'warn');
  }catch(e){toast('❌ Error al actualizar','err');}
}

/* DETALLE */
function verDet(tipo,id){
  let html='';
  if(tipo==='c'){
    const c=CLS[id];if(!c)return;
    html=dr('Asignatura','<strong>'+c.asignatura+'</strong>')+dr('Espacio',c.aula)+dr('Jornada',c.jornada+' / '+c.modalidad)+dr('Docente',c.docente||'—')+dr('Horario',c.hi+' – '+c.hf)+dr('Período',mesL(c.fi)+' → '+mesL(c.ff))+dr('Días',c.dia||'L–V');
    document.getElementById('btnEditDet').style.display='none';
    document.getElementById('detTit').innerHTML='<i class="bi bi-book"></i> Clase Programada';
  }else{
    const r=RSV[id];if(!r)return;
    const TL={dep:'🏢 Dependencia ESAP',est:'🎓 Estudiante',ext:'🌐 Externo'};
    html=dr('Evento','<strong>'+r.evento+'</strong>')+dr('Espacio',r.aula)+dr('Tipo de solicitante',TL[r.tipo]||'—')+dr('Solicitante',nombre(r))+dr('Dependencia/Área',depLabel(r))+dr('Correo',correo(r)||'—')+(r.telefono?dr('Teléfono',r.telefono):'')+dr('Fecha',mesL(r.fecha))+dr('Horario',r.hi+' – '+r.hf)+dr('Estado',r.estado)+(r.obs?dr('Observaciones',r.obs):'')+dr('Agendado por',r.creadoPor||'—')+(r.editadoPor?dr('Última edición por',r.editadoPor+' · '+r.fechaEdicion):'');
    const puedeEditar = USUARIO_ACTUAL && ['admin','gestor'].includes(USUARIO_ACTUAL.rol);
    document.getElementById('btnEditDet').style.display=puedeEditar?'inline-flex':'none';
    document.getElementById('btnEditDet').onclick=()=>{cerrar('ovDet');setTimeout(()=>editarRsv(id),180);};
    // Add approve/reject for gestor and admin
    const puedeAprobar=USUARIO_ACTUAL&&['admin','gestor'].includes(USUARIO_ACTUAL.rol);
    const footEl=document.querySelector('#ovDet .pan-foot');
    // Remove previous approve/reject buttons
    footEl.querySelectorAll('.btn-aprobar,.btn-rechazar').forEach(b=>b.remove());
    if(puedeAprobar&&r&&r.estado==='pendiente'){
      const btnApr=document.createElement('button');
      btnApr.className='btn btn-green btn-aprobar';
      btnApr.innerHTML='<i class="bi bi-check-lg"></i> Aprobar';
      btnApr.onclick=()=>cambiarEstado(id,'confirmada');
      const btnRech=document.createElement('button');
      btnRech.className='btn btn-red btn-rechazar';
      btnRech.innerHTML='<i class="bi bi-x-lg"></i> Rechazar';
      btnRech.onclick=()=>cambiarEstado(id,'rechazada');
      footEl.insertBefore(btnRech,footEl.firstChild);
      footEl.insertBefore(btnApr,footEl.firstChild);
    }
    document.getElementById('detTit').innerHTML='<i class="bi bi-calendar-check"></i> Detalle de Reserva';
  }
  document.getElementById('detBody').innerHTML=html;
  document.getElementById('ovDet').classList.add('open');
}

/* EXPORTAR */
function exportarExcel(){
  const rows=[['TIPO','ESPACIO','FECHA','H.INI','H.FIN','EVENTO','SOLICITANTE','DEPENDENCIA/TIPO','CORREO','ESTADO','OBSERVACIONES']];
  rsvArr().sort((a,b)=>b.fecha.localeCompare(a.fecha)).forEach(r=>{const s=CAT.find(x=>x.id===r.aula);rows.push(['RESERVA',s?s.n:r.aula,r.fecha,r.hi,r.hf,r.evento,nombre(r),depLabel(r),correo(r)||'',r.estado,r.obs||'']);});
  const csv=rows.map(r=>r.map(c=>'"'+String(c).replace(/"/g,'""')+'"').join(',')).join('\r\n');
  const a=document.createElement('a');a.href=URL.createObjectURL(new Blob(['﻿'+csv],{type:'text/csv;charset=utf-8'}));a.download='RESERVAS_ESAP_'+FECHA+'.csv';a.click();
  toast('✓ Exportado a Excel','ok');
}
function exportarPDF(){
  const rsvs=rsvArr().sort((a,b)=>b.fecha.localeCompare(a.fecha));
  const html='<html><head><meta charset="UTF-8"><title>Reservas ESAP</title><style>body{font-family:Arial,sans-serif;font-size:11px;padding:20px}h1{color:#1a3a5c;font-size:16px}p{color:#64748b;margin-bottom:15px}table{width:100%;border-collapse:collapse}th{background:#1a3a5c;color:#fff;padding:7px 9px;text-align:left;font-size:10px}td{padding:6px 9px;border-bottom:1px solid #e2e8f0}tr:nth-child(even) td{background:#f8fafc}</style></head><body><h1>🏫 Gestión de Salones — ESAP</h1><p>'+new Date().toLocaleDateString('es-CO',{weekday:'long',year:'numeric',month:'long',day:'numeric'})+' | '+rsvs.length+' reservas</p><table><thead><tr><th>Fecha</th><th>Espacio</th><th>Tipo</th><th>Solicitante</th><th>Evento</th><th>Horario</th><th>Estado</th></tr></thead><tbody>'+rsvs.map(r=>{const s=CAT.find(x=>x.id===r.aula);const TL={dep:'Dep.',est:'Est.',ext:'Ext.'};return'<tr><td>'+fC(r.fecha)+'</td><td>'+(s?s.n:r.aula)+'</td><td>'+(TL[r.tipo]||'—')+'</td><td>'+nombre(r)+'</td><td>'+r.evento+'</td><td>'+r.hi+'–'+r.hf+'</td><td>'+r.estado+'</td></tr>';}).join('')+'</tbody></table></body></html>';
  const w=window.open('','_blank');w.document.write(html);w.document.close();setTimeout(()=>w.print(),500);
  toast('✓ PDF generado','ok');
}

/* CARGA EXCEL */
function abrirCargaExcel(){bufA=[];renderArchivosList();document.getElementById('ovExcel').classList.add('open');}
function onFilePick(e){agregarArchivos([...e.target.files]);e.target.value='';}
function onDrop(e){e.preventDefault();document.getElementById('dropZone').classList.remove('drag');agregarArchivos([...e.dataTransfer.files].filter(f=>/\.xlsx?$/i.test(f.name)));}
function agregarArchivos(files){files.forEach(f=>{if(!bufA.find(b=>b.nombre===f.name)){const n=f.name.toLowerCase();let m='Otro';if(n.includes('pregr'))m='Pregrado';else if(n.includes('posgr')||n.includes('esp')||n.includes('maest'))m='Posgrado';else if(n.includes('apt'))m='APT';bufA.push({file:f,nombre:f.name,m});}});renderArchivosList();}
function renderArchivosList(){
  const l=document.getElementById('archivosList'),w=document.getElementById('warnReemplazar'),b=document.getElementById('btnConfExcel');
  if(!bufA.length){l.innerHTML='';w.style.display='none';b.disabled=true;return;}
  w.style.display=CLS.length?'block':'none';b.disabled=false;
  l.innerHTML=bufA.map((b,i)=>'<div style="display:flex;align-items:center;gap:10px;padding:9px 12px;background:var(--gris-bg);border:1px solid var(--border);border-radius:var(--radius-sm);margin-bottom:7px"><i class="bi bi-file-earmark-excel" style="font-size:20px;color:#16a34a"></i><div style="flex:1;font-size:12px;font-weight:700;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="'+b.nombre+'">'+b.nombre+'</div><select style="padding:3px 7px;border:1px solid var(--border);border-radius:5px;font-size:11px;font-weight:700;background:var(--card)" onchange="bufA['+i+'].m=this.value"><option '+(b.m==='Pregrado'?'selected':'')+'>Pregrado</option><option '+(b.m==='Posgrado'?'selected':'')+'>Posgrado</option><option '+(b.m==='APT'?'selected':'')+'>APT</option><option '+(b.m==='Otro'?'selected':'')+'>Otro</option></select><button style="background:none;border:none;color:var(--rojo);font-size:17px;cursor:pointer" onclick="bufA.splice('+i+',1);renderArchivosList()">✕</button></div>').join('');
}
async function confirmarCargaExcel(){
  if(!bufA.length)return;
  const btn=document.getElementById('btnConfExcel');btn.innerHTML='<span class="spinner"></span> Procesando…';btn.disabled=true;
  try{
    const results=await Promise.all(bufA.map(b=>leerExcel(b.file,b.m)));
    CLS=[];PROGS=[];
    results.forEach((r,i)=>{CLS.push(...r.clases);PROGS.push({n:bufA[i].nombre.replace(/\.xlsx?$/i,'').replace(/_/g,' '),m:bufA[i].m,tot:r.clases.length,fi:r.fi?fmtD(r.fi):null,ff:r.ff?fmtD(r.ff):null});});
    rebuildAulas();
    const pf=PROGS.map(p=>p.fi).filter(Boolean).sort()[0];
    if(pf){FECHA=pf;document.getElementById('ctrlFecha').value=FECHA;}
    cerrar('ovExcel');actualizarBanner();render();
    toast('✅ '+CLS.length+' clases cargadas de '+PROGS.length+' archivo(s)','ok');
  }catch(e){toast('❌ '+e,'err');}
  finally{btn.innerHTML='<i class="bi bi-check-lg"></i> Aplicar Programación';btn.disabled=false;}
}
function leerExcel(file,modalidad){
  return new Promise((res,rej)=>{
    const reader=new FileReader();
    reader.onload=e=>{
      try{
        const wb=XLSX.read(e.target.result,{type:'binary',cellDates:true});
        const ws=wb.Sheets[wb.SheetNames[0]];
        const raw=XLSX.utils.sheet_to_json(ws,{header:1,defval:''});
        const hIdx=raw.reduce((b,r,i)=>{const sc=r.filter(c=>String(c).trim().length>2).length;return sc>b.sc?{i,sc}:b;},{i:0,sc:0}).i;
        const h=raw[hIdx];
        const iA=fndC(h,'aula','salon','salón'),iN=fndC(h,'asignatura','materia','curso'),iHI=fndC(h,'hora inicio','hora_inicio'),iHF=fndC(h,'hora fin','hora_fin'),iJ=fndC(h,'jornada'),iP=fndC(h,'programa'),iD=fndC(h,'docente','nombre docente'),iFI=fndC(h,'fecha inicio','desde'),iFF=fndC(h,'fecha fin','hasta');
        if(iA<0)throw new Error('Sin columna Aula');if(iN<0)throw new Error('Sin columna Asignatura');if(iHI<0)throw new Error('Sin columna Hora Inicio');if(iHF<0)throw new Error('Sin columna Hora Fin');
        const clases=[];let fi=null,ff=null;
        for(let r=hIdx+1;r<raw.length;r++){
          const row=raw[r];if(!row||row.every(c=>!String(c).trim()))continue;
          const aula=normAula(String(row[iA]||'').trim());if(!aula)continue;
          const hi=parseH(row[iHI]),hf=parseH(row[iHF]);if(!hi||!hf)continue;
          const fIx=iFI>=0?parseF(row[iFI]):null,fFx=iFF>=0?parseF(row[iFF]):null;
          const fiS=fIx?fmtD(fIx):'2026-01-01',ffS=fFx?fmtD(fFx):'2026-12-31';
          if(fIx&&(!fi||fIx<fi))fi=fIx;if(fFx&&(!ff||fFx>ff))ff=fFx;
          const j=String(row[iJ]||'').trim()||'Diurna';
          const color=modalidad==='APT'?'c-apt':modalidad==='Posgrado'||j==='Nocturna'?'c-noc':'c-diu';
          clases.push({aula,modalidad,jornada:j,programa:String(row[iP]||'').trim()||modalidad,asignatura:String(row[iN]||'').trim(),docente:String(row[iD]||'').trim(),hi,hf,fi:fiS,ff:ffS,dia:'L-V',color});
        }
        res({clases,fi,ff});
      }catch(err){rej(err.message||'Error: '+file.name);}
    };
    reader.onerror=()=>rej('No se pudo leer '+file.name);
    reader.readAsBinaryString(file);
  });
}

/* MODO OSCURO */
