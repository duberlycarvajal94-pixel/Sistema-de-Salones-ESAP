/* BÚSQUEDA INTELIGENTE */
function renderBusqueda(){
  document.getElementById('tabBusqueda').innerHTML='<div style="background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:18px;margin-bottom:14px"><div style="font-weight:800;color:var(--navy);font-size:14px;margin-bottom:12px"><i class="bi bi-search"></i> Búsqueda Inteligente de Espacios</div><div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:10px;margin-bottom:12px"><div><div class="lbl" style="margin-bottom:4px">Capacidad mínima</div><input class="ctrl" id="bCap" type="number" placeholder="Ej: 40" style="width:100%"/></div><div><div class="lbl" style="margin-bottom:4px">Fecha</div><input class="ctrl" id="bFecha" type="date" value="'+FECHA+'" style="width:100%"/></div><div><div class="lbl" style="margin-bottom:4px">Hora inicio</div><input class="ctrl" id="bHI" type="time" step="1800" style="width:100%"/></div><div><div class="lbl" style="margin-bottom:4px">Hora fin</div><input class="ctrl" id="bHF" type="time" step="1800" style="width:100%"/></div></div><div style="display:flex;gap:14px;flex-wrap:wrap;margin-bottom:14px"><label style="display:flex;align-items:center;gap:5px;font-size:12px;cursor:pointer"><input type="checkbox" id="bVB"/> Video beam</label><label style="display:flex;align-items:center;gap:5px;font-size:12px;cursor:pointer"><input type="checkbox" id="bPC"/> Computadores</label><label style="display:flex;align-items:center;gap:5px;font-size:12px;cursor:pointer"><input type="checkbox" id="bAC"/> Aire acondicionado</label><label style="display:flex;align-items:center;gap:5px;font-size:12px;cursor:pointer"><input type="checkbox" id="bSON"/> Sistema de sonido</label></div><button class="btn btn-teal" onclick="ejecutarBusqueda()"><i class="bi bi-search"></i> Buscar Espacio Disponible</button></div><div id="bResultados"></div>';
}
function ejecutarBusqueda(){
  const cap=parseInt(document.getElementById('bCap').value)||0;
  const fecha=document.getElementById('bFecha').value||FECHA;
  const hi=document.getElementById('bHI').value;
  const hf=document.getElementById('bHF').value;
  const vb=document.getElementById('bVB').checked;
  const pc=document.getElementById('bPC').checked;
  const ac=document.getElementById('bAC').checked;
  const son=document.getElementById('bSON').checked;
  const fD=strD(fecha);
  const res=CAT.filter(s=>{
    if(s.cap<cap)return false;
    if(vb&&!s.e.vb)return false;
    if(pc&&!s.e.pc)return false;
    if(ac&&!s.e.ac)return false;
    if(son&&!s.e.son)return false;
    if(hi&&hf){
      const ocCls=CLS.some(c=>c.aula===s.id&&esL(fecha)&&fD>=strD(c.fi)&&fD<=strD(c.ff)&&solapa(hi,hf,c.hi,c.hf));
      const ocRsv=rsvArr().some(r=>r.aula===s.id&&r.fecha===fecha&&solapa(hi,hf,r.hi,r.hf));
      if(ocCls||ocRsv)return false;
    }
    return true;
  });
  const el=document.getElementById('bResultados');
  if(!res.length){el.innerHTML='<div class="empty-state"><span class="es-ico">🔍</span>Sin espacios disponibles con esos criterios</div>';return;}
  el.innerHTML='<div style="font-weight:700;color:var(--verde);margin-bottom:12px"><i class="bi bi-check-circle"></i> '+res.length+' espacio(s) disponible(s):</div><div class="inv-grid">'+res.map(s=>{const equips=Object.entries(s.e).filter(([k,v])=>v).map(([k])=>'<span class="inv-tag">'+EN[k]+'</span>').join('');return'<div class="inv-card"><div class="inv-nombre"><i class="bi bi-door-open"></i> '+s.n+'</div><div class="inv-cap"><i class="bi bi-people"></i> '+s.cap+' personas · Piso '+s.p+'</div><div class="inv-equip">'+equips+'</div><div style="display:flex;gap:6px;margin-top:10px"><button class="btn btn-outline btn-sm" onclick="abrirFicha(&quot;'+s.id+'&quot;)"><i class="bi bi-info-circle"></i> Ficha</button><button class="btn btn-teal btn-sm" style="flex:1" onclick="fichaRsv(this)" data-a="'+s.id+'" data-h="'+(hi||'08:00')+'"><i class="bi bi-calendar-plus"></i> Reservar</button></div></div>';}).join('')+'</div>';
}

