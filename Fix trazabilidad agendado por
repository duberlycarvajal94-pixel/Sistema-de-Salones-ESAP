/* ALERTAS DE PENDIENTES */
let notifPermiso = false;
let ultimoContPend = 0;

function verificarPendientes(){
  const pend = rsvArr().filter(r => r.estado === 'pendiente');
  const cont = pend.length;

  // Badge en tab historial
  const badge = document.getElementById('badgePend');
  if(badge){
    badge.textContent = cont;
    badge.style.display = cont > 0 ? 'inline' : 'none';
  }

  // Banner alerta
  const alertaBanner = document.getElementById('alertaPendientes');
  const alertaTxt = document.getElementById('alertaPendTxt');
  if(alertaBanner){
    if(cont > 0 && USUARIO_ACTUAL && ['admin','gestor'].includes(USUARIO_ACTUAL.rol)){
      alertaBanner.style.display = 'flex';
      alertaTxt.textContent = cont === 1
        ? '⚠️ Tiene 1 reserva pendiente de aprobación'
        : '⚠️ Tiene ' + cont + ' reservas pendientes de aprobación';
    } else {
      alertaBanner.style.display = 'none';
    }
  }

  // Notificación del navegador si hay nuevas pendientes
  if(cont > ultimoContPend && ultimoContPend >= 0 && document.hidden){
    enviarNotifNavegador(
      '🔔 Nueva solicitud pendiente — ESAP',
      cont + ' reserva(s) esperan aprobación en el Sistema de Salones'
    );
  }
  ultimoContPend = cont;
}

function irAPendientes(){
  // Ir al historial y filtrar pendientes
  const tab = document.querySelector('[data-mt="historial"]');
  if(tab) tab.click();
  setTimeout(()=>{
    const hT = document.getElementById('hT');
    if(hT){ hT.value = ''; renderHistorial(); }
  }, 300);
}

function pedirPermisoNotificaciones(){
  if(!('Notification' in window)) return;
  if(Notification.permission === 'granted'){
    notifPermiso = true;
  } else if(Notification.permission !== 'denied'){
    Notification.requestPermission().then(p => {
      notifPermiso = p === 'granted';
    });
  }
}

function enviarNotifNavegador(titulo, cuerpo){
  if(!notifPermiso || Notification.permission !== 'granted') return;
  try{
    const n = new Notification(titulo, {
      body: cuerpo,
      icon: '🏫',
      badge: '🏫',
      tag: 'salones-esap-pendiente',
      requireInteraction: true
    });
    n.onclick = () => { window.focus(); irAPendientes(); n.close(); };
  }catch(e){}
}

/* KPI */
function renderKPI(){
  const fD=strD(FECHA);
  const clsD=esL(FECHA)?CLS.filter(c=>fD>=strD(c.fi)&&fD<=strD(c.ff)):[];
  const oc=new Set(clsD.map(c=>c.aula));
  const rH=rsvArr().filter(r=>r.fecha===FECHA);
  const pen=rH.filter(r=>r.estado==='pendiente').length;
  const mn=rsvArr().filter(r=>r.estado==='mantenimiento').length;
  const hoy=fmtD(new Date());
  const lun=new Date(strD(hoy));lun.setDate(lun.getDate()-(lun.getDay()||7)+1);
  const sem=Array.from({length:7},(_,i)=>fmtD(new Date(lun.getTime()+i*86400000)));
  const rSem=rsvArr().filter(r=>sem.includes(r.fecha)).length;
  const pct=AULAS.length?Math.round((oc.size/AULAS.length)*100):0;
  document.getElementById('kTot').textContent=AULAS.length;
  document.getElementById('kLib').textContent=Math.max(0,AULAS.length-oc.size-mn);
  document.getElementById('kOcup').textContent=oc.size+rH.filter(r=>r.estado==='confirmada').length;
  document.getElementById('kMant').textContent=mn;
  document.getElementById('kHoy').textContent=rH.length;
  document.getElementById('kSem').textContent=rSem;
  document.getElementById('kPct').textContent=pct+'%';
}

/* CELDA */
function clsEn(a,f,fr){if(!esL(f))return null;const fD=strD(f),s=sigF(fr);const fm=document.getElementById('ctrlModalidad').value;return CLS.find(c=>c.aula===a&&fD>=strD(c.fi)&&fD<=strD(c.ff)&&solapa(c.hi,c.hf,fr,s)&&(!fm||c.modalidad===fm))||null;}
function rsvEn(a,f,fr){const s=sigF(fr);return rsvArr().find(r=>r.aula===a&&r.fecha===f&&solapa(r.hi,r.hf,fr,s))||null;}
function estCel(a,f,fr){const r=rsvEn(a,f,fr);if(r){return r.estado==='pendiente'?'pend':r.estado==='mantenimiento'?'mant':r.estado==='bloqueado'?'bloq':'ocup';}const c=clsEn(a,f,fr);if(c)return c.color||'c-diu';return'libre';}
function celCls(e){return{libre:'c-libre',ocup:'c-rojo',pend:'c-naranja',mant:'c-gris',bloq:'c-azul','c-diu':'c-diu','c-noc':'c-noc','c-apt':'c-apt'}[e]||'c-libre';}

/* GRILLA */
function getFR(){const v=document.getElementById('ctrlFranja').value;if(v==='m')return FR.filter(f=>tm(f)<13*60);if(v==='t')return FR.filter(f=>tm(f)>=13*60&&tm(f)<18*60);if(v==='n')return FR.filter(f=>tm(f)>=18*60);return FR;}
function getAU(){const ff=document.getElementById('ctrlFiltro').value,fr=getFR();if(ff==='libre')return AULAS.filter(a=>fr.some(f=>estCel(a,FECHA,f)==='libre'));if(ff==='ocup')return AULAS.filter(a=>fr.some(f=>estCel(a,FECHA,f)!=='libre'));if(ff==='mant')return AULAS.filter(a=>rsvArr().some(r=>r.aula===a&&r.estado==='mantenimiento'));return AULAS;}
function ICO(e){return{libre:'✚',ocup:'📌',pend:'⏳',mant:'🔧',bloq:'🔒','c-diu':'☀️','c-noc':'🌙','c-apt':'🔵'}[e]||'✚';}
function TAG_TXT(c){return{dep:'DEP',est:'EST',ext:'EXT'}[c]||'';}
function TAG_CLS(t){return{dep:'tag-dep',est:'tag-est',ext:'tag-ext'}[t]||'';}

function renderGrilla(){
  const frs=getFR(),aus=getAU();
  if(!aus.length&&!AULAS.length){document.getElementById('vistaGrilla').innerHTML='<div class="empty-state"><span class="es-ico">📂</span>Sin programación — use el botón "Programación"</div>';return;}
  const ths=frs.map(f=>'<th>'+f+'<br><span style="font-size:9px;opacity:.55">'+sigF(f)+'</span></th>').join('');
  const rows=aus.map(aula=>{
    const s=CAT.find(x=>x.id===aula);
    const cells=[];let skip=0;
    frs.forEach((fr,fi)=>{
      if(skip>0){skip--;cells.push(null);return;}
      const est=estCel(aula,FECHA,fr);
      const cc=celCls(est);
      const r=(est==='ocup'||est==='pend'||est==='mant'||est==='bloq')?rsvEn(aula,FECHA,fr):null;
      const c=(est==='c-diu'||est==='c-noc'||est==='c-apt')?clsEn(aula,FECHA,fr):null;
      let span=1;
      if(r){for(let k=fi+1;k<frs.length;k++){const rx=rsvEn(aula,FECHA,frs[k]);if(rx&&rx.id===r.id)span++;else break;}}
      else if(c){for(let k=fi+1;k<frs.length;k++){const cx=clsEn(aula,FECHA,frs[k]);if(cx&&cx===c)span++;else break;}}
      skip=span-1;
      let cell='';
      if(r){
        const tl=TAG_TXT(r.tipo),tcl=TAG_CLS(r.tipo);
        const nomb=r.tipo==='est'?r.estNombre:r.tipo==='ext'?r.extEnt:r.dependencia;
        cell='<td class="cel '+cc+' cel-new" colspan="'+span+'" onclick="verDet(&quot;r&quot;,&quot;'+r.id+'&quot;)" title="'+r.evento+'"><div class="cel-in"><div class="cel-ico">'+ICO(est)+'</div><div class="cel-txt">'+trunc(tl?tl+' — ':''+(r.evento||''),20)+'</div><div class="cel-sub">'+trunc(nomb||'',18)+'</div><div class="cel-sub">⏰'+r.hi+'–'+r.hf+'</div>'+(tl?'<span class="cel-tag '+tcl+'">'+tl+'</span>':'')+'</div></td>';
      }else if(c){
        cell='<td class="cel '+cc+'" colspan="'+span+'" onclick="verDet(&quot;c&quot;,'+CLS.indexOf(c)+')" title="'+c.asignatura+'"><div class="cel-in"><div class="cel-ico">'+ICO(est)+'</div><div class="cel-txt">'+trunc(c.asignatura,20)+'</div><div class="cel-sub">'+trunc(c.docente,18)+'</div><div class="cel-sub">⏰'+c.hi+'–'+c.hf+'</div></div></td>';
      }else if(est==='mant'){
        cell='<td class="cel c-gris" colspan="'+span+'"><div class="cel-in"><div class="cel-ico">🔧</div><div class="cel-txt" style="color:var(--muted)">Mantenimiento</div></div></td>';
      }else if(est==='bloq'){
        cell='<td class="cel c-azul" colspan="'+span+'"><div class="cel-in"><div class="cel-ico">🔒</div><div class="cel-txt" style="color:var(--azul)">Bloqueado</div></div></td>';
      }else{
        cell='<td class="cel c-libre" colspan="'+span+'" onclick="abrirNuevaDesde(&quot;'+aula+'&quot;,&quot;'+fr+'&quot;)" title="Disponible"><div class="cel-in"><div class="cel-ico" style="opacity:.4">✚</div><div class="cel-txt" style="color:var(--libre)">DISPONIBLE</div><div class="cel-sub" style="color:var(--libre)">Clic para reservar</div></div></td>';
      }
      cells.push(cell);
    });
    const hasR=frs.some(f=>['ocup','pend'].includes(estCel(aula,FECHA,f)));
    const hasC=frs.some(f=>['c-diu','c-noc','c-apt'].includes(estCel(aula,FECHA,f)));
    const col=hasR?'var(--rojo)':hasC?'#b45309':'var(--verde)';
    return'<tr><td style="color:'+col+'" onclick="abrirFicha(&quot;'+aula+'&quot;)" title="Ver ficha técnica">'+( s?s.n:aula )+'</td>'+cells.filter(Boolean).join('')+'</tr>';
  }).join('');
  document.getElementById('vistaGrilla').innerHTML='<div style="font-weight:800;color:var(--navy);font-size:13px;margin-bottom:10px;padding-bottom:7px;border-bottom:2px solid var(--teal)"><i class="bi bi-calendar3"></i> '+nomDiaL(FECHA)+', '+mesL(FECHA)+(esL(FECHA)?'':' — Fin de semana / Festivo')+'</div><div class="grilla-wrap"><table class="grilla"><thead><tr><th style="text-align:left;padding-left:10px;min-width:140px">Espacio / Hora →</th>'+ths+'</tr></thead><tbody>'+(rows||'<tr><td colspan="99" style="padding:30px;text-align:center;color:var(--muted)">Sin espacios</td></tr>')+'</tbody></table></div>';
}

