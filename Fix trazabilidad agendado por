  const r=RSV[fbKey];if(!r)return;
  EDID=fbKey;
  const t=r.tipo||'dep';
  selTipo(t);
  document.getElementById('rsvTit').innerHTML='<i class="bi bi-pencil"></i> Editar Reserva';
  document.getElementById('btnDel').style.display=(USUARIO_ACTUAL&&USUARIO_ACTUAL.rol==='admin')?'inline-flex':'none';
  document.getElementById('rsvAlerta').className='alerta-form';
  document.getElementById('rsvOk').className='alerta-ok';
  limpiarCampos();
  document.getElementById('fSalon').value=r.aula||'';
  document.getElementById('fEvento').value=r.evento||'';
  document.getElementById('fFecha').value=r.fecha||'';
  document.getElementById('fHI').value=r.hi||'';
  document.getElementById('fHF').value=r.hf||'';
  document.getElementById('fEstado').value=r.estado||'confirmada';
  document.getElementById('fObs').value=r.obs||'';
  if(t==='dep'){
    const ds=document.getElementById('fDepSel');
    const opts=[...ds.options].map(o=>o.value);
