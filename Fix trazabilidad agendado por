/* RENDER PRINCIPAL */
function actualizarVista(){
  const hayAulas=AULAS.length>0;
  document.getElementById('msgVacio').style.display=hayAulas?'none':'block';
  const showGrilla=hayAulas&&TAB==='grilla'&&VISTA==='grilla';
  const showLista=hayAulas&&TAB==='grilla'&&VISTA==='lista';
  document.getElementById('vGrilla').style.display=showGrilla?'block':'none';
  document.getElementById('vistaGrilla').style.display=showGrilla?'block':'none';
  document.getElementById('vistaLista').style.display=showLista?'flex':'none';
  document.getElementById('tabHistorial').style.display=TAB==='historial'?'block':'none';
  document.getElementById('tabInventario').style.display=TAB==='inventario'?'block':'none';
  document.getElementById('tabIndicadores').style.display=TAB==='indicadores'?'block':'none';
  document.getElementById('tabBusqueda').style.display=TAB==='busqueda'?'block':'none';
  if(hayAulas)render();
}
function render(){
  renderKPI();
  verificarPendientes();
  if(TAB==='grilla'){if(VISTA==='grilla')renderGrilla();else renderLista();}
  else if(TAB==='historial')renderHistorial();
  else if(TAB==='inventario')renderInventario();
  else if(TAB==='busqueda')renderBusqueda();
  else if(TAB==='indicadores')renderIndicadores();
}

/* INDICADORES — DASHBOARD COMPLETO */
function renderIndicadores(){
  const rs=rsvArr();
  const hoy=fmtD(new Date());
  // Semana actual
  const lunD=new Date(strD(hoy));lunD.setDate(lunD.getDate()-(lunD.getDay()||7)+1);
  const semFechas=Array.from({length:7},(_,i)=>fmtD(new Date(lunD.getTime()+i*86400000)));
  // Mes actual
  const mesAct=hoy.slice(0,7);
  // Conteos
  const rsHoy=rs.filter(r=>r.fecha===hoy);
  const rsSem=rs.filter(r=>semFechas.includes(r.fecha));
  const rsMes=rs.filter(r=>r.fecha&&r.fecha.startsWith(mesAct));
  const rsPend=rs.filter(r=>r.estado==='pendiente');

  // Agrupaciones
  const topAulas={},topDeps={},topUsers={},porMes={},tipos={dep:0,est:0,ext:0};
  const porDiaSem={'Lun':0,'Mar':0,'Mié':0,'Jue':0,'Vie':0,'Sáb':0,'Dom':0};
  const diasMap=['Dom','Lun','Mar','Mié','Jue','Vie','Sáb'];
  rs.forEach(r=>{
    topAulas[r.aula]=(topAulas[r.aula]||0)+1;
    const dep=depLabel(r)||'Sin dep.';
    topDeps[dep]=(topDeps[dep]||0)+1;
    const usr=r.creadoPor||'Sin registrar';
    topUsers[usr]=(topUsers[usr]||0)+1;
    const m=r.fecha?.slice(0,7)||'';
    if(m)porMes[m]=(porMes[m]||0)+1;
    tipos[r.tipo||'dep']=(tipos[r.tipo||'dep']||0)+1;
    if(r.fecha){const dia=diasMap[strD(r.fecha).getDay()];if(porDiaSem[dia]!==undefined)porDiaSem[dia]++;}
  });
  const topA=Object.entries(topAulas).sort((a,b)=>b[1]-a[1]).slice(0,7);
  const topD=Object.entries(topDeps).sort((a,b)=>b[1]-a[1]).slice(0,7);
  const topU=Object.entries(topUsers).sort((a,b)=>b[1]-a[1]).slice(0,5);
  const porMA=Object.entries(porMes).sort().slice(-8);
  const maxA=topA[0]?.[1]||1,maxD=topD[0]?.[1]||1,maxU=topU[0]?.[1]||1,maxM=Math.max(...porMA.map(x=>x[1]),1);
  const maxDS=Math.max(...Object.values(porDiaSem),1);
  const tot=rs.length||1;

  const barras=(arr,max,color)=>arr.map(([k,v])=>`
    <div class="bar-item">
      <div class="bar-label">${trunc(k,20)}</div>
      <div class="bar-track"><div class="bar-fill" style="width:${Math.round(v/max*100)}%;background:${color}"></div></div>
      <div class="bar-val">${v}</div>
    </div>`).join('');

  const kpiTop=`
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:10px;margin-bottom:18px">
      ${[
        {v:rs.length,  l:'Total reservas',    c:'var(--teal)',   i:'bi-calendar-check'},
        {v:rsHoy.length,l:'Hoy',              c:'var(--azul)',   i:'bi-calendar-day'},
        {v:rsSem.length,l:'Esta semana',       c:'var(--morado)', i:'bi-calendar-week'},
        {v:rsMes.length,l:'Este mes',          c:'var(--naranja)',i:'bi-calendar-month'},
        {v:rsPend.length,l:'Pendientes',       c:'var(--naranja)',i:'bi-clock-history'},
        {v:rs.filter(r=>r.estado==='confirmada').length,l:'Confirmadas',c:'var(--verde)',i:'bi-check-circle'},
      ].map(k=>`<div style="background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:14px;text-align:center;box-shadow:var(--shadow)">
        <div style="font-size:24px;font-weight:800;color:${k.c}">${k.v}</div>
        <div style="font-size:10px;color:var(--muted);margin-top:3px"><i class="bi ${k.i}"></i> ${k.l}</div>
      </div>`).join('')}
    </div>`;

  const diaSemBars=Object.entries(porDiaSem).map(([d,v])=>`
    <div style="display:flex;flex-direction:column;align-items:center;gap:4px;flex:1">
      <div style="font-size:11px;font-weight:700;color:var(--teal)">${v}</div>
      <div style="width:100%;background:var(--border);border-radius:4px;height:60px;display:flex;align-items:flex-end">
        <div style="width:100%;background:var(--teal);border-radius:4px;height:${Math.round(v/maxDS*100)}%;min-height:${v?4:0}px;transition:height .5s ease"></div>
      </div>
      <div style="font-size:10px;color:var(--muted)">${d}</div>
    </div>`).join('');

  const recentesRows=rs.sort((a,b)=>(b.ts||0)-(a.ts||0)).slice(0,8).map(r=>`
    <tr>
      <td>${fC(r.fecha)}</td>
      <td><strong>${r.aula}</strong></td>
      <td>${trunc(r.evento,22)}</td>
      <td>${trunc(nombre(r),18)}</td>
      <td>${trunc(r.creadoPor||'—',15)}</td>
      <td><span style="background:${r.estado==='confirmada'?'var(--libre-bg)':r.estado==='pendiente'?'var(--pend-bg)':'var(--gris-bg)'};color:${r.estado==='confirmada'?'var(--libre)':r.estado==='pendiente'?'var(--pend)':'var(--muted)'};border-radius:999px;padding:2px 8px;font-size:10px;font-weight:700">${r.estado}</span></td>
    </tr>`).join('');

  document.getElementById('tabIndicadores').innerHTML=`
    <div style="margin-bottom:16px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px">
      <div style="font-weight:800;color:var(--navy);font-size:15px"><i class="bi bi-bar-chart-line"></i> Dashboard — Indicadores de Gestión</div>
      <div style="font-size:11px;color:var(--muted)">Actualizado en tiempo real · ${mesL(hoy)}</div>
    </div>
    ${kpiTop}
    <div class="dash-grid">
      <div class="dash-card" style="grid-column:span 2">
        <h3><i class="bi bi-calendar-week"></i> Reservas por día de la semana (histórico)</h3>
        <div style="display:flex;gap:8px;align-items:flex-end;height:80px;padding:0 4px">${diaSemBars}</div>
      </div>
      <div class="dash-card">
        <h3><i class="bi bi-building"></i> Espacios más solicitados</h3>
        ${topA.length?barras(topA,maxA,'var(--teal)'):'<p style="color:var(--muted);font-size:12px">Sin datos aún</p>'}
      </div>
      <div class="dash-card">
        <h3><i class="bi bi-diagram-3"></i> Dependencias / solicitantes frecuentes</h3>
        ${topD.length?barras(topD,maxD,'var(--morado)'):'<p style="color:var(--muted);font-size:12px">Sin datos aún</p>'}
      </div>
      <div class="dash-card">
        <h3><i class="bi bi-calendar3"></i> Reservas por mes</h3>
        ${porMA.length?barras(porMA,maxM,'var(--naranja)'):'<p style="color:var(--muted);font-size:12px">Sin datos aún</p>'}
      </div>
      <div class="dash-card">
        <h3><i class="bi bi-person-check"></i> Agendamientos por usuario del sistema</h3>
        ${topU.length?barras(topU,maxU,'var(--azul)'):'<p style="color:var(--muted);font-size:12px">Sin datos aún</p>'}
        <div style="margin-top:10px;padding-top:8px;border-top:1px solid var(--border);font-size:11px;color:var(--muted)">
          <i class="bi bi-people"></i> Tipo de solicitante:<br>
          🏢 Dependencia: <strong>${tipos.dep||0}</strong> &nbsp;
          🎓 Estudiante: <strong>${tipos.est||0}</strong> &nbsp;
          🌐 Externo: <strong>${tipos.ext||0}</strong>
        </div>
      </div>
    </div>
    <div class="dash-card" style="margin-top:14px">
      <h3><i class="bi bi-clock-history"></i> Últimas 8 reservas registradas</h3>
      <div style="overflow-x:auto">
        <table style="width:100%;border-collapse:collapse;font-size:11px">
          <thead><tr style="background:var(--navy);color:#fff">
            <th style="padding:6px 9px;text-align:left">Fecha</th>
            <th style="padding:6px 9px;text-align:left">Espacio</th>
            <th style="padding:6px 9px;text-align:left">Evento</th>
            <th style="padding:6px 9px;text-align:left">Solicitante</th>
            <th style="padding:6px 9px;text-align:left">Agendado por</th>
            <th style="padding:6px 9px;text-align:left">Estado</th>
          </tr></thead>
          <tbody>${recentesRows||'<tr><td colspan="6" style="padding:20px;text-align:center;color:var(--muted)">Sin reservas registradas aún</td></tr>'}</tbody>
        </table>
      </div>
    </div>`;
}

/* EVENTOS */
document.addEventListener('DOMContentLoaded',()=>{
  document.getElementById('inputClave').focus();
  document.getElementById('ctrlFecha').value=FECHA;

  // Nav tabs
  document.querySelectorAll('.ntab').forEach(t=>{
    t.addEventListener('click',()=>{
      document.querySelectorAll('.ntab').forEach(x=>x.classList.remove('on'));
      t.classList.add('on');TAB=t.dataset.tab;
      document.getElementById('vGrilla').style.display='none'; if(document.getElementById('vistaGrilla'))document.getElementById('vistaGrilla').style.display='none';
      document.getElementById('vistaGrilla').style.display='none';
      document.getElementById('vistaLista').style.display='none';
      ['tabHistorial','tabInventario','tabIndicadores','tabBusqueda'].forEach(id=>document.getElementById(id).style.display='none');
      if(TAB==='busqueda')renderBusqueda();
      actualizarVista();
    });
  });

  // View tabs
  document.querySelectorAll('.vtab').forEach(t=>{
    t.addEventListener('click',()=>{
      document.querySelectorAll('.vtab').forEach(x=>x.classList.remove('on'));
      t.classList.add('on');VISTA=t.dataset.view;
      document.getElementById('vistaGrilla').style.display='none';
      document.getElementById('vistaLista').style.display='none';
      if(AULAS.length)render();
    });
  });

  // Fecha
  document.getElementById('ctrlFecha').addEventListener('change',e=>{FECHA=e.target.value;if(AULAS.length)render();});
  document.getElementById('btnPrev').addEventListener('click',()=>{FECHA=addD(FECHA,-1);document.getElementById('ctrlFecha').value=FECHA;if(AULAS.length)render();});
  document.getElementById('btnNext').addEventListener('click',()=>{FECHA=addD(FECHA,1);document.getElementById('ctrlFecha').value=FECHA;if(AULAS.length)render();});
  document.getElementById('btnHoy').addEventListener('click',()=>{FECHA=fmtD(new Date());document.getElementById('ctrlFecha').value=FECHA;if(AULAS.length)render();});

  // Filtros grilla
  ['ctrlFranja','ctrlModalidad','ctrlFiltro'].forEach(id=>document.getElementById(id).addEventListener('change',()=>{if(AULAS.length&&TAB==='grilla')render();}));

  // Cerrar overlays
  ['ovExcel','ovRsv','ovDet','ovFicha'].forEach(id=>document.getElementById(id).addEventListener('click',e=>{if(e.target===e.currentTarget)cerrar(id);}));

  // Login enter
  document.getElementById('inputClave').addEventListener('keydown',e=>{if(e.key==='Enter')validarAcceso();});
});
</script>
