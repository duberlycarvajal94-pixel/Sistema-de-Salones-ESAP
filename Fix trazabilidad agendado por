<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Sistema de Gestión de Aulas — ESAP</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
<style>
:root{
  --navy:#1a3a5c;--navy2:#0f2540;--teal:#0d9488;--teal2:#0a7367;
  --bg:#f0f4f8;--card:#fff;--border:#d1dce8;--txt:#1e293b;--muted:#64748b;
  --verde:#16a34a;--verde-bg:#dcfce7;--verde-b:#4ade80;
  --rojo:#dc2626;--rojo-bg:#fee2e2;--rojo-b:#f87171;
  --naranja:#ea580c;--naranja-bg:#ffedd5;--naranja-b:#fb923c;
  --gris:#6b7280;--gris-bg:#f3f4f6;--gris-b:#9ca3af;
  --azul:#2563eb;--azul-bg:#dbeafe;--azul-b:#60a5fa;
  --morado:#7c3aed;--morado-bg:#ede9fe;--morado-b:#a78bfa;
  --shadow:0 1px 6px rgba(0,0,0,.09);--shadow-lg:0 8px 30px rgba(0,0,0,.15);
  --radius:10px;--radius-sm:6px;
}
[data-theme="dark"]{--bg:#0f172a;--card:#1e293b;--border:#334155;--txt:#e2e8f0;--muted:#94a3b8;--navy:#0f2540;--navy2:#0a1929;--gris-bg:#1e293b;}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);font-family:'Segoe UI',system-ui,sans-serif;font-size:14px;color:var(--txt);transition:background .3s,color .3s;}
button{cursor:pointer;font-family:inherit;}
input,select,textarea{font-family:inherit;}

/* ACCESO */
#pantallaAcceso{position:fixed;inset:0;background:linear-gradient(135deg,#0f2540 0%,#1a3a5c 50%,#0d9488 100%);display:flex;align-items:center;justify-content:center;z-index:9999;}
.login-card{background:#fff;border-radius:20px;padding:44px 40px;width:400px;max-width:94vw;box-shadow:0 32px 80px rgba(0,0,0,.4);text-align:center;}
.login-logo{font-size:56px;margin-bottom:10px;}
.login-card h2{font-size:22px;font-weight:800;color:var(--navy);margin-bottom:4px;}
.login-card p{font-size:13px;color:var(--muted);margin-bottom:28px;}
.login-card input{width:100%;padding:13px 16px;border:2px solid #e2e8f0;border-radius:10px;font-size:16px;text-align:center;letter-spacing:4px;outline:none;transition:border .2s;margin-bottom:14px;}
.login-card input:focus{border-color:var(--teal);}
.login-card .btn-ingresar{width:100%;padding:13px;background:var(--teal);color:#fff;border:none;border-radius:10px;font-size:15px;font-weight:700;transition:.2s;}
.login-card .btn-ingresar:hover{background:var(--teal2);}
.login-err{color:var(--rojo);font-size:12px;margin-top:8px;display:none;}
.login-err.on{display:block;}

/* APP */
#app{display:none;min-height:100vh;flex-direction:column;}
#app.visible{display:flex;}

/* HEADER */
.header{background:var(--navy);color:#fff;padding:0 18px;height:56px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:200;box-shadow:0 2px 12px rgba(0,0,0,.3);gap:12px;}
.header-brand{display:flex;align-items:center;gap:10px;flex-shrink:0;}
.header-brand h1{font-size:15px;font-weight:800;white-space:nowrap;}
.header-brand span{font-size:11px;opacity:.6;}
.header-actions{display:flex;align-items:center;gap:7px;flex-wrap:wrap;}
.sync-pill{display:inline-flex;align-items:center;gap:5px;background:rgba(255,255,255,.1);border-radius:999px;padding:3px 9px;font-size:11px;font-weight:600;}
.sync-dot{width:8px;height:8px;border-radius:50%;}
.sync-dot.verde{background:#4ade80;animation:pulso 2s infinite;}
.sync-dot.rojo{background:#f87171;}
.sync-dot.ama{background:#fbbf24;}
@keyframes pulso{0%,100%{opacity:1;}50%{opacity:.3;}}

/* BOTONES */
.btn{padding:7px 14px;border:none;border-radius:var(--radius-sm);font-size:12px;font-weight:700;transition:.15s;display:inline-flex;align-items:center;gap:5px;white-space:nowrap;}
.btn-teal{background:var(--teal);color:#fff;}.btn-teal:hover{background:var(--teal2);}
.btn-ghost{background:rgba(255,255,255,.12);color:#d1fae5;border:1px solid rgba(255,255,255,.2);}.btn-ghost:hover{background:rgba(255,255,255,.2);}
.btn-red{background:var(--rojo);color:#fff;}.btn-red:hover{background:#b91c1c;}
.btn-gray{background:var(--gris-bg);color:var(--txt);border:1px solid var(--border);}.btn-gray:hover{background:#e5e7eb;}
.btn-outline{background:transparent;color:var(--teal);border:1px solid var(--teal);}.btn-outline:hover{background:#f0fdf9;}
.btn-sm{padding:4px 10px;font-size:11px;}
.btn-green{background:#16a34a;color:#fff;border:none;}.btn-green:hover{background:#15803d;}
.btn-icon{padding:6px;border-radius:var(--radius-sm);background:var(--gris-bg);border:1px solid var(--border);color:var(--muted);font-size:14px;}.btn-icon:hover{background:var(--border);}
.dark-toggle{background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);color:#fff;border-radius:999px;padding:4px 10px;font-size:11px;font-weight:700;}

/* NAV TABS */
.nav-tabs-main{background:var(--navy2);display:flex;gap:2px;padding:0 18px;border-bottom:1px solid rgba(255,255,255,.08);overflow-x:auto;}
.nav-tabs-main::-webkit-scrollbar{height:0;}
.ntab{padding:10px 16px;font-size:12px;font-weight:700;color:rgba(255,255,255,.6);border:none;background:none;border-bottom:3px solid transparent;white-space:nowrap;transition:.15s;display:flex;align-items:center;gap:6px;}
.ntab:hover{color:rgba(255,255,255,.9);}
.ntab.on{color:#fff;border-bottom-color:var(--teal);}

/* BANNER */
.banner-prog{background:linear-gradient(90deg,#1e3a5f,#1a4a6b);color:#e0f2fe;padding:6px 18px;font-size:11px;display:none;align-items:center;gap:10px;flex-wrap:wrap;}
.banner-prog.visible{display:flex;}
.prog-tag{background:rgba(255,255,255,.15);border-radius:999px;padding:3px 10px;font-weight:700;font-size:11px;}

/* KPI */
.kpi-bar{display:grid;grid-template-columns:repeat(auto-fit,minmax(100px,1fr));gap:8px;padding:10px 18px;background:var(--navy2);}
.kpi-card{background:rgba(255,255,255,.08);border-radius:var(--radius-sm);padding:9px 12px;display:flex;align-items:center;gap:9px;}
.kpi-icon{width:34px;height:34px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0;}
.kpi-val{font-size:19px;font-weight:800;color:#fff;line-height:1;}
.kpi-lbl{font-size:10px;color:#94a3b8;margin-top:1px;white-space:nowrap;}
.ki-verde{background:rgba(74,222,128,.2);color:#4ade80;}.ki-rojo{background:rgba(248,113,113,.2);color:#f87171;}
.ki-ama{background:rgba(251,191,36,.2);color:#fbbf24;}.ki-azul{background:rgba(96,165,250,.2);color:#60a5fa;}
.ki-gris{background:rgba(156,163,175,.2);color:#9ca3af;}.ki-morado{background:rgba(167,139,250,.2);color:#a78bfa;}
.ki-teal{background:rgba(45,212,191,.2);color:#2dd4bf;}

/* CONTENT */
.content{flex:1;padding:14px 18px 40px;}

/* TOOLBAR */
.toolbar{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:10px 14px;display:flex;align-items:center;gap:7px;flex-wrap:wrap;margin-bottom:12px;box-shadow:var(--shadow);}
.view-tabs{display:flex;gap:3px;}
.vtab{padding:5px 11px;border-radius:var(--radius-sm);border:1px solid var(--border);background:var(--gris-bg);color:var(--muted);font-size:11px;font-weight:700;transition:.15s;}
.vtab.on{background:var(--navy);color:#fff;border-color:var(--navy);}
.ctrl{padding:6px 9px;border-radius:var(--radius-sm);border:1px solid var(--border);background:var(--card);font-size:12px;color:var(--txt);outline:none;}
.ctrl:focus{border-color:var(--teal);}
.sep{width:1px;height:22px;background:var(--border);margin:0 2px;}
.lbl{font-size:11px;color:var(--muted);font-weight:700;white-space:nowrap;}

/* LEYENDA */
.leyenda{display:flex;gap:12px;flex-wrap:wrap;padding:6px 0;font-size:11px;margin-bottom:10px;}
.ley{display:flex;align-items:center;gap:4px;font-weight:700;}
.ley-dot{width:12px;height:12px;border-radius:3px;flex-shrink:0;}

/* GRILLA */
.grilla-wrap{overflow:auto;max-height:calc(100vh - 300px);border-radius:var(--radius);box-shadow:var(--shadow);}
table.grilla{border-collapse:separate;border-spacing:0;min-width:800px;width:100%;font-size:11px;}
table.grilla th{background:var(--navy);color:#fff;text-align:center;padding:7px 4px;font-weight:700;white-space:nowrap;border:1px solid #2a527a;position:sticky;top:0;z-index:3;}
table.grilla th:first-child{position:sticky;left:0;top:0;z-index:4;min-width:140px;text-align:left;padding-left:10px;background:var(--navy2);}
table.grilla tbody td:first-child{background:var(--card);font-weight:800;color:var(--navy);position:sticky;left:0;z-index:2;border-right:3px solid var(--border);padding:5px 10px;white-space:nowrap;font-size:11px;cursor:pointer;border-bottom:1px solid var(--border);}
table.grilla tbody td:first-child:hover{background:#f0fdf9;}
table.grilla tbody tr:hover td{filter:brightness(.97);}
.cel{border:1px solid var(--border);vertical-align:top;min-width:86px;transition:background .2s;}
.c-libre{background:var(--verde-bg);cursor:pointer;}.c-libre:hover{background:#bbf7d0!important;}
.c-rojo{background:var(--rojo-bg);cursor:pointer;}.c-rojo:hover{background:#fca5a5!important;}
.c-naranja{background:var(--naranja-bg);cursor:pointer;}.c-naranja:hover{background:#fed7aa!important;}
.c-gris{background:var(--gris-bg);}.c-azul{background:var(--azul-bg);cursor:pointer;}.c-azul:hover{background:#bfdbfe!important;}
.c-diu{background:#fef3c7;cursor:pointer;}.c-diu:hover{background:#fde68a!important;}
.c-noc{background:#dbeafe;cursor:pointer;}.c-noc:hover{background:#bfdbfe!important;}
@keyframes celNew{0%{opacity:.2;transform:scale(.93);}100%{opacity:1;transform:scale(1);}}
.cel-new{animation:celNew .3s ease;}
.cel-in{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:62px;padding:4px 3px;text-align:center;gap:1px;}
.cel-ico{font-size:14px;line-height:1;}
.cel-txt{font-size:10px;line-height:1.25;word-break:break-word;max-width:108px;font-weight:700;}
.cel-sub{font-size:9px;opacity:.75;line-height:1.2;max-width:108px;}
.cel-tag{font-size:8px;font-weight:800;border-radius:999px;padding:1px 5px;margin-top:2px;}
.tag-dep{background:#dbeafe;color:#1d4ed8;}.tag-est{background:#dcfce7;color:#166534;}.tag-ext{background:#fce7f3;color:#9d174d;}

/* LISTA */
.lista-wrap{display:flex;flex-direction:column;gap:7px;}
.lcard{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:11px 15px;display:flex;align-items:center;gap:12px;box-shadow:var(--shadow);transition:.15s;}
.lcard:hover{box-shadow:var(--shadow-lg);transform:translateY(-1px);}
.lnum{width:44px;height:44px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0;}
.linf{flex:1;min-width:0;}.linf h3{font-size:13px;font-weight:700;margin-bottom:2px;}
.linf p{font-size:11px;color:var(--muted);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.lbadge{padding:3px 9px;border-radius:999px;font-size:10px;font-weight:800;white-space:nowrap;flex-shrink:0;}
.lac{display:flex;gap:5px;flex-shrink:0;}

/* OVERLAY */
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:600;align-items:center;justify-content:center;padding:16px;}
.overlay.open{display:flex;}
.panel{background:var(--card);border-radius:16px;width:560px;max-width:98vw;max-height:94vh;overflow-y:auto;box-shadow:var(--shadow-lg);animation:panIn .2s ease;}
.panel-lg{width:680px;}.panel-xl{width:860px;}
@keyframes panIn{from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:translateY(0);}}
.pan-hdr{background:var(--navy);color:#fff;padding:14px 18px;border-radius:16px 16px 0 0;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:1;}
.pan-hdr h2{font-size:15px;font-weight:700;display:flex;align-items:center;gap:8px;}
.pan-close{background:none;border:none;color:#94a3b8;font-size:20px;cursor:pointer;line-height:1;}
.pan-close:hover{color:#fff;}
.pan-body{padding:18px;}.pan-foot{padding:13px 18px;border-top:1px solid var(--border);display:flex;gap:8px;justify-content:flex-end;flex-wrap:wrap;}

/* FORMULARIO */
.field{margin-bottom:13px;}
.field label{display:block;font-size:11px;font-weight:700;color:var(--muted);margin-bottom:4px;text-transform:uppercase;letter-spacing:.04em;}
.field input,.field select,.field textarea{width:100%;padding:9px 11px;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-size:13px;color:var(--txt);background:var(--card);outline:none;transition:border .15s;}
.field input:focus,.field select:focus,.field textarea:focus{border-color:var(--teal);}
.field textarea{resize:vertical;min-height:55px;}
.r2{display:grid;grid-template-columns:1fr 1fr;gap:13px;}
.r3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:13px;}
.alerta-form{background:var(--rojo-bg);color:var(--rojo);border:1px solid var(--rojo-b);border-radius:var(--radius-sm);padding:10px 13px;font-size:12px;margin-bottom:13px;display:none;}
.alerta-form.on{display:block;}
.alerta-ok{background:var(--verde-bg);color:var(--verde);border:1px solid var(--verde-b);border-radius:var(--radius-sm);padding:10px 13px;font-size:12px;margin-bottom:13px;display:none;}
.alerta-ok.on{display:block;}

/* TIPO SOLICITANTE */
.tipo-tabs{display:flex;gap:6px;margin-bottom:16px;}
.tipo-tab{flex:1;padding:10px;border:2px solid var(--border);border-radius:var(--radius-sm);text-align:center;cursor:pointer;transition:.15s;background:var(--gris-bg);}
.tipo-tab:hover,.tipo-tab.on{border-color:var(--teal);background:#f0fdf9;}
.tipo-tab .tt-ico{font-size:22px;display:block;margin-bottom:4px;}
.tipo-tab .tt-txt{font-size:11px;font-weight:700;}
.form-seccion{display:none;}.form-seccion.on{display:block;}

/* INVENTARIO */
.inv-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(215px,1fr));gap:12px;}
.inv-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:14px;box-shadow:var(--shadow);cursor:pointer;transition:.15s;}
.inv-card:hover{box-shadow:var(--shadow-lg);transform:translateY(-2px);}
.inv-nombre{font-size:14px;font-weight:800;color:var(--navy);margin-bottom:4px;}
.inv-cap{font-size:11px;color:var(--muted);margin-bottom:6px;}
.inv-equip{display:flex;gap:4px;flex-wrap:wrap;margin-top:6px;}
.inv-tag{font-size:9px;padding:2px 7px;border-radius:999px;background:var(--azul-bg);color:var(--azul);font-weight:700;}
.badge-estado{display:inline-block;padding:3px 9px;border-radius:999px;font-size:10px;font-weight:800;}
.be-libre{background:var(--verde-bg);color:var(--verde);}
.be-mant{background:var(--gris-bg);color:var(--gris);}
.be-bloq{background:var(--azul-bg);color:var(--azul);}

/* FICHA */
.ficha-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px;}
.ficha-section{background:var(--gris-bg);border-radius:var(--radius-sm);padding:13px;}
.ficha-section h4{font-size:12px;font-weight:800;color:var(--navy);margin-bottom:9px;text-transform:uppercase;letter-spacing:.04em;}
.equip-item{display:flex;align-items:center;justify-content:space-between;padding:4px 0;border-bottom:1px solid var(--border);font-size:12px;}
.equip-item:last-child{border-bottom:none;}

/* HISTORIAL */
.historial-filtros{display:flex;gap:7px;flex-wrap:wrap;margin-bottom:12px;padding:11px;background:var(--gris-bg);border-radius:var(--radius-sm);}
.hist-table{width:100%;border-collapse:collapse;font-size:11px;}
.hist-table th{background:var(--navy);color:#fff;padding:7px 9px;text-align:left;font-weight:700;}
.hist-table td{padding:7px 9px;border-bottom:1px solid var(--border);}
.hist-table tr:hover td{background:var(--gris-bg);}
.hist-actions{display:flex;gap:4px;}

/* DASHBOARD */
.dash-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(270px,1fr));gap:14px;}
.dash-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:16px;box-shadow:var(--shadow);}
.dash-card h3{font-size:13px;font-weight:800;color:var(--navy);margin-bottom:12px;display:flex;align-items:center;gap:6px;}
.dash-card[style*="span 2"]{grid-column:span 2;}
@media(max-width:640px){.dash-card[style*="span 2"]{grid-column:span 1;}}
.bar-item{display:flex;align-items:center;gap:9px;margin-bottom:7px;font-size:12px;}
.bar-label{min-width:115px;color:var(--muted);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.bar-track{flex:1;height:8px;background:var(--border);border-radius:999px;overflow:hidden;}
.bar-fill{height:100%;border-radius:999px;background:var(--teal);transition:width .6s ease;}
.bar-val{min-width:28px;text-align:right;font-weight:700;}

/* DETALLE */
.det-row{display:flex;gap:11px;padding:7px 0;border-bottom:1px solid var(--border);align-items:flex-start;}
.det-row:last-child{border-bottom:none;}
.det-lbl{min-width:115px;font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.03em;flex-shrink:0;}
.det-val{font-size:13px;}

/* BÚSQUEDA */
.search-result{background:var(--card);border:1px solid var(--verde-b);border-radius:var(--radius-sm);padding:10px 14px;margin-bottom:8px;display:flex;align-items:center;gap:12px;box-shadow:var(--shadow);}
.sr-aula{font-weight:800;font-size:14px;color:var(--navy);}
.sr-info{font-size:11px;color:var(--muted);}

/* TOAST */
.toast-wrap{position:fixed;bottom:18px;right:18px;z-index:999;display:flex;flex-direction:column;gap:5px;pointer-events:none;}
.tst{padding:10px 15px;border-radius:10px;color:#fff;font-size:12px;font-weight:700;box-shadow:0 4px 20px rgba(0,0,0,.25);animation:tIn .2s ease;max-width:310px;pointer-events:all;display:flex;align-items:center;gap:7px;}
.tst.ok{background:#065f46;}.tst.err{background:#991b1b;}.tst.warn{background:#78350f;}.tst.info{background:#1e40af;}
@keyframes tIn{from{opacity:0;transform:translateX(28px);}to{opacity:1;transform:translateX(0);}}
.spinner{display:inline-block;width:14px;height:14px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin .7s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}
.empty-state{text-align:center;padding:48px 20px;color:var(--muted);}
.empty-state .es-ico{font-size:46px;opacity:.3;display:block;margin-bottom:10px;}
::-webkit-scrollbar{width:6px;height:6px;}
::-webkit-scrollbar-track{background:var(--gris-bg);}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:99px;}
@media(max-width:640px){.header-brand h1{font-size:12px;}.kpi-bar{grid-template-columns:repeat(3,1fr);}.r2,.r3{grid-template-columns:1fr;}.ficha-grid{grid-template-columns:1fr;}.content{padding:10px 12px 30px;}.tipo-tabs{flex-direction:column;}}
</style>
</head>
<body>
<div id="pantallaAcceso">
  <div class="login-card">
    <div class="login-logo">🏫</div>
    <h2>Sistema de Gestión de Aulas</h2>
    <p>Escuela Superior de Administración Pública<br>Sede Principal — Bogotá</p>
    <input type="text" id="inputUsuario" placeholder="Su nombre" style="margin-bottom:10px;letter-spacing:normal;text-align:left" onkeydown="if(event.key==='Enter')document.getElementById('inputClave').focus()"/>
    <input type="password" id="inputClave" placeholder="Contraseña de acceso" onkeydown="if(event.key==='Enter')validarAcceso()"/>
    <button class="btn-ingresar" onclick="validarAcceso()"><i class="bi bi-box-arrow-in-right"></i> Ingresar al Sistema</button>
    <div class="login-err" id="loginError">❌ Contraseña incorrecta. Intente de nuevo.</div>
  </div>
</div>

<div id="app">
  <div class="header">
    <div class="header-brand">
      <span style="font-size:22px">🏫</span>
      <div>
        <h1>Gestión de Aulas — ESAP</h1>
        <span><span class="sync-pill"><span class="sync-dot ama" id="syncDot"></span><span id="syncTxt">Conectando…</span></span></span>
      </div>
    </div>
    <div class="header-actions">
      <div style="display:flex;align-items:center;gap:6px;background:rgba(255,255,255,.1);border-radius:999px;padding:4px 11px;font-size:11px;color:#e0f2fe;flex-shrink:0">
